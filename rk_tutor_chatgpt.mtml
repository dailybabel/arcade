<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Rubik's Cube Tutor</title>
<style>
  body { margin:0; overflow:hidden; font-family:system-ui; background:#0f1115; color:#fff; }
  #ui { position:absolute; top:0; left:0; right:0; padding:10px; display:flex; justify-content:space-between; pointer-events:none;}
  .panel { background:rgba(20,22,28,0.85); backdrop-filter:blur(8px); border-radius:10px; padding:10px; pointer-events:auto; }
  button, select { margin:2px; padding:6px 10px; border:none; border-radius:6px; background:#2b2f3a; color:#fff; cursor:pointer;}
  button:hover { background:#3a3f4d;}
  #controls { position:absolute; bottom:10px; left:10px; max-width:95vw;}
  #rules { position:absolute; right:10px; bottom:10px; width:260px;}
  #status { font-size:12px; opacity:0.7; }
</style>
</head>
<body>

<div id="ui">
  <div class="panel">
    <b>Rubik's Cube Tutor</b><br/>
    <button onclick="app.scramble()">Scramble</button>
    <button onclick="app.reset()">Reset</button>
    <button onclick="app.undo()">Undo</button>
    <button onclick="app.redo()">Redo</button>
    <br/>
    <button onclick="app.snap('front')">Front</button>
    <button onclick="app.snap('corner')">Front-Right</button>
    <button onclick="app.snap('top')">Top</button>
    <div id="status"></div>
  </div>
</div>

<div id="controls" class="panel"></div>

<div id="rules" class="panel">
  <select id="ruleSelect"></select>
  <div id="ruleDesc"></div>
  <button onclick="app.playRule()">Play Rule</button>
  <button onclick="app.stepMode()">Step Mode</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>

<script>
class CubeEngine {
  constructor() {
    this.reset();
  }

  reset() {
    this.cubies = [];
    this.history = [];
    this.future = [];
    const colors = {
      U:0xffff00,D:0xffffff,F:0x00ff00,B:0x0000ff,L:0xff8000,R:0xff0000
    };
    for(let x=-1;x<=1;x++)
    for(let y=-1;y<=1;y++)
    for(let z=-1;z<=1;z++){
      this.cubies.push({
        pos:{x,y,z},
        rot:new THREE.Euler(0,0,0),
        mesh:null
      });
    }
  }
}

class Renderer {
  constructor(engine) {
    this.engine = engine;
    this.scene = new THREE.Scene();
    this.camera = new THREE.PerspectiveCamera(60, innerWidth/innerHeight, 0.1, 100);
    this.camera.position.set(5,5,5);

    this.renderer = new THREE.WebGLRenderer({antialias:true});
    this.renderer.setSize(innerWidth, innerHeight);
    document.body.appendChild(this.renderer.domElement);

    this.controls();
    this.buildCube();
    this.animate();
  }

  controls(){
    let dragging=false, px=0, py=0;
    window.addEventListener('mousedown',e=>{dragging=true;px=e.clientX;py=e.clientY});
    window.addEventListener('mouseup',()=>dragging=false);
    window.addEventListener('mousemove',e=>{
      if(!dragging)return;
      let dx=e.clientX-px, dy=e.clientY-py;
      px=e.clientX; py=e.clientY;
      this.camera.position.applyAxisAngle(new THREE.Vector3(0,1,0), -dx*0.005);
      this.camera.position.applyAxisAngle(new THREE.Vector3(1,0,0), -dy*0.005);
      this.camera.lookAt(0,0,0);
    });
    window.addEventListener('wheel',e=>{
      this.camera.position.multiplyScalar(1+e.deltaY*0.001);
    });
  }

  buildCube(){
    const geo = new THREE.BoxGeometry(0.95,0.95,0.95);
    this.engine.cubies.forEach(c=>{
      let mats=[
        new THREE.MeshStandardMaterial({color:0xff8000}),
        new THREE.MeshStandardMaterial({color:0xff0000}),
        new THREE.MeshStandardMaterial({color:0xffff00}),
        new THREE.MeshStandardMaterial({color:0xffffff}),
        new THREE.MeshStandardMaterial({color:0x00ff00}),
        new THREE.MeshStandardMaterial({color:0x0000ff})
      ];
      let mesh=new THREE.Mesh(geo,mats);
      mesh.position.set(c.pos.x,c.pos.y,c.pos.z);
      this.scene.add(mesh);
      c.mesh=mesh;
    });

    let light=new THREE.DirectionalLight(0xffffff,1);
    light.position.set(5,5,5);
    this.scene.add(light);
    this.scene.add(new THREE.AmbientLight(0x404040));
  }

  animate(){
    requestAnimationFrame(()=>this.animate());
    this.renderer.render(this.scene,this.camera);
  }
}

class App {
  constructor(){
    this.engine=new CubeEngine();
    this.renderer=new Renderer(this.engine);
    this.queue=[];
    this.animating=false;
    this.speed=200;
    this.rules=this.loadRules();
    this.initUI();
  }

  loadRules(){
    return [
      {id:"RT",name:"Right Trigger",desc:"Right insert",moves:"R U R'"},
      {id:"LT",name:"Left Trigger",desc:"Left insert",moves:"L' U' L"},
      {id:"YELLOW_CROSS",name:"Yellow Cross",desc:"Make cross",moves:"F R U R' U' F'"}
    ];
  }

  initUI(){
    const ctrl=document.getElementById('controls');
    const moves=["F","R","U","L","D","F'","R'","U'","L'","D'","U2","R2"];
    moves.forEach(m=>{
      let b=document.createElement('button');
      b.innerText=m;
      b.onclick=()=>this.enqueue([m]);
      ctrl.appendChild(b);
    });

    const sel=document.getElementById('ruleSelect');
    this.rules.forEach(r=>{
      let o=document.createElement('option');
      o.value=r.id;
      o.textContent=r.name;
      sel.appendChild(o);
    });

    sel.onchange=()=>{
      let r=this.rules.find(x=>x.id===sel.value);
      document.getElementById('ruleDesc').innerText=r.desc+"\n"+r.moves;
    };
    sel.dispatchEvent(new Event('change'));
  }

  enqueue(moves){
    this.queue.push(...moves);
    this.process();
  }

  process(){
    if(this.animating || !this.queue.length) return;
    let m=this.queue.shift();
    this.animating=true;
    this.animateMove(m, ()=> {
      this.animating=false;
      this.process();
    });
  }

  animateMove(move, cb){
    let axis='y', layer=1, dir=1;
    if(move.includes("'")) dir=-1;
    if(move[0]==='U'){axis='y'; layer=1;}
    if(move[0]==='D'){axis='y'; layer=-1;}
    if(move[0]==='R'){axis='x'; layer=1;}
    if(move[0]==='L'){axis='x'; layer=-1;}
    if(move[0]==='F'){axis='z'; layer=1;}
    if(move[0]==='B'){axis='z'; layer=-1;}

    let group=new THREE.Group();
    this.renderer.scene.add(group);

    let affected=this.engine.cubies.filter(c=>c.pos[axis]===layer);
    affected.forEach(c=>group.attach(c.mesh));

    let start=performance.now();
    let duration=this.speed;

    const anim=()=>{
      let t=(performance.now()-start)/duration;
      if(t>=1){
        let angle=Math.PI/2*dir;
        group.rotation[axis]=angle;
        affected.forEach(c=>{
          this.renderer.scene.attach(c.mesh);
        });
        this.renderer.scene.remove(group);
        cb();
        return;
      }
      group.rotation[axis]=Math.PI/2*dir*t;
      requestAnimationFrame(anim);
    };
    anim();
  }

  scramble(){
    const faces=["R","L","U","D","F","B"];
    let seq=[];
    for(let i=0;i<25;i++){
      let m=faces[Math.floor(Math.random()*6)];
      if(Math.random()>0.5)m+="'";
      seq.push(m);
    }
    this.enqueue(seq);
  }

  reset(){ location.reload(); }
  undo(){}
  redo(){}

  snap(type){
    let c=this.renderer.camera.position;
    if(type==="front") c.set(0,0,6);
    if(type==="top") c.set(0,6,0);
    if(type==="corner") c.set(5,5,5);
    this.renderer.camera.lookAt(0,0,0);
  }

  playRule(){
    let id=document.getElementById('ruleSelect').value;
    let r=this.rules.find(x=>x.id===id);
    this.enqueue(r.moves.split(" "));
  }

  stepMode(){
    alert("Step mode placeholder (full validation system would go here)");
  }
}

const app=new App();
</script>
</body>
</html>
